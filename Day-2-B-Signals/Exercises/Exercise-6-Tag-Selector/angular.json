{
  "name": "exercise-6-tag-selector",
  "version": "0.0.0",
  "projects": {
    "exercise-6-tag-selector": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/exercise-6-tag-selector",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [],
            "styles": ["src/styles.css"],
            "scripts": []
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "exercise-6-tag-selector:build:production" },
            "development": { "buildTarget": "exercise-6-tag-selector:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
